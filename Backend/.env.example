# ─── Core Django ──────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production-use-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://lipuser:lippass@postgres:5432/logplatform

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_HOSTS=http://elasticsearch:9200
ES_INDEX_PREFIX=logs

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ─── AI Service ───────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://ai_service:8001

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@logplatform.io

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# ─── Sentry (Production) ──────────────────────────────────────────────────────
SENTRY_DSN=